msgstr "Інформація про станцію оновлений Онлайн - Перегляд змін"

#: src/Widgets/StationContextMenu.vala:92
msgid "Update Station from Online"
msgstr "Станція оновлень онлайн"

#: src/Widgets/StationContextMenu.vala:100
