#, c-format
msgid "%s Star this station"
msgstr "%s Ajouter cette station comme favorite"

#, c-format
msgid "%s Unstar this station"
msgstr "%s Retirer cette station des favorites"

msgid "About"
msgstr "À propos"

msgid "Album"
msgstr "Album"

msgid "Application Name"
msgstr "Nom d'application"

msgid "Artist"
msgstr "Artiste"

msgid "Audio Codec"
msgstr "Codec audio"

