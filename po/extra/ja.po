#~ msgstr "チューナー翻訳言語"

#~ msgid "Tuner Jukebox and options popover"
#~ msgstr "チューナーJukeboxとオプションのポップアップ"

#~ msgid "Tuner genres and subgenres"
#~ msgstr "チューナーのジャンルとサブジャンル"

#~ msgid "Tuner with dark theme, saved search"
#~ msgstr "暗いテーマでチューナー、保存された検索"
