msgstr "Popular"

msgid "Preferences"
msgstr "Preferencias"

msgid "Private Data"
msgstr "Datos privados"

msgid "Remove this saved search"
msgstr "Saca esto búsqueda salvada"

msgid "Requires restarting Tuner"
msgstr "Requiere reiniciar Tuner"

msgid "Save File"
msgstr "Guardar Archivo"

msgid "Save this search"
msgstr "Guarda esta búsqueda"

msgid "Saved Search"
msgstr "Búsqueda Guardada"

msgid "Saved Searches"
msgstr "Búsquedas Guardadas"

msgid "Search Results"
msgstr "Resultados de Búsqueda"

msgid "Selections"
msgstr "Selecciones"

msgid "Show stream info when playing"
msgstr "Mostrar información de la transmisión durante la reproducción"

msgid ""
"Something went wrong loading radio stations data from station provider. "
"Please try again later."
msgstr ""
"Algo salió mal cargando datos de las estaciones de radio del proveedor de la "
"estación. Por favor, intente de nuevo más tarde."

msgid "Star this station"
msgstr "Agregar a Favoritas"

msgid "Starred by You"
msgstr "Destacado por ti"

msgid "Station Search"
msgstr "Búsqueda de Estaciones"

msgid "Station info updated Online - View changes"
msgstr "Información de la estación actualizada en línea - Ver cambios"

msgid "Station no longer in the index"
msgstr "La estación ya no se encuentra en el índice"

