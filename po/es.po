msgstr "Gramola"

msgid "Language"
msgstr "Idioma"

msgid "Latest Search"
msgstr "Búsqueda última"

msgid "Library"
msgstr "Biblioteca"

msgid "Light mode"
msgstr "Modo claro"

msgid "Location"
msgstr "Ubicación"

msgid "Maximum Bitrate"
msgstr "Tasa de bits Máxima"

msgid "Minimum Bitrate"
msgstr "Tasa de bits Mínima"

msgid "Most listened to Stations in the last 24 hours"
msgstr "Emisoras más escuchadas en las últimas 24 horas"

msgid "No stations found"
msgstr "Estación no encontrada"

msgid "Nominal Bitrate"
msgstr "Tasa de bits Nominal"

msgid "Nothing here"
msgstr "No hay nada aquí"

